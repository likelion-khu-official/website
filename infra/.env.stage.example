SPRING_PROFILES_ACTIVE=stage
JWT_SECRET=
DB_PATH=/app/data/stage.db

# 모집 안내 등 일반 사용자 대상 메일의 링크 베이스 — 공개 사이트(stage). 안 채우면 application.yml
# 기본값(prod 주소)으로 빠져서 stage에서 보낸 메일이 prod 사이트를 가리키게 됨 — #124 리뷰에서 발견.
PUBLIC_SITE_URL=https://dev.likelion-khu.com

# 지원폼(#152) 완성 전까지 모집 열기를 막는 스위치(#154 결정: B) — stage는 검증 환경이라
# true. prod(.env.prod)는 #152가 끝날 때까지 false를 유지한다.
RECRUITMENT_APPLICATION_FORM_READY=true

# Object Storage — OCI (S3 호환 API). namespace: nrvbyrcay0ao, region: ap-tokyo-1, 버킷 Public
OCI_STORAGE_ENDPOINT=https://nrvbyrcay0ao.compat.objectstorage.ap-tokyo-1.oraclecloud.com
OCI_STORAGE_REGION=ap-tokyo-1
OCI_STORAGE_ACCESS_KEY=
OCI_STORAGE_SECRET_KEY=
OCI_STORAGE_BUCKET=likelion-stage
OCI_STORAGE_PUBLIC_URL=https://objectstorage.ap-tokyo-1.oraclecloud.com/n/nrvbyrcay0ao/b/likelion-stage/o

# Mail — OCI Email Delivery (SMTP, issue #75). 자격증명은 인프라(찬욱)가 안전한 채널로 전달 — 레포엔 값 채우지 말 것
MAIL_SMTP_HOST=smtp.email.ap-tokyo-1.oci.oraclecloud.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=noreply@likelion-khu.com
