# backup-db.sh / backup_upload.py가 쓰는 OCI Object Storage(S3 호환) 자격증명/설정.
# 실제 값을 채운 .env.backup은 절대 커밋하지 않는다(.gitignore 처리됨).
# 발급: likelion-backup-writer 그룹 소속 전용 서비스 계정의 Customer Secret Key만 사용 —
#   인프라 오너(Administrators) 계정 키를 여기 쓰지 않는다(블라스트 반경 최소화, pm/docs/learnings.md 참고).
#
# 업로드는 boto3(backup_upload.py)로 한다 — aws-cli v2는 사용하지 않음(간헐적 서명 실패 확인,
# pm/docs/learnings.md 참고).

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

OCI_S3_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
OCI_S3_REGION=ap-tokyo-1
BACKUP_BUCKET=likelion-backups
