# Database
DB_PATH=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRATION=
JWT_REFRESH_EXPIRATION=

# 어드민 인증(#90)
ADMIN_LOCKOUT_MAX_ATTEMPTS=
ADMIN_LOCKOUT_DURATION_MINUTES=
# 포맷: "email:name,email2:name2" — 실제 이메일은 이 파일(커밋 대상)에 절대 넣지 말 것
ADMIN_SEED_SUPER_ADMINS=
FRONTEND_BASE_URL=
# 일반 사용자 대상 메일(모집 안내 등)의 링크 베이스 — 공개 사이트 주소. FRONTEND_BASE_URL(어드민)과 혼동 금지.
PUBLIC_SITE_URL=
COOKIE_SECURE=
# 지원폼(#152) 완성 전까지 모집 열기를 막는 스위치(#154 결정: B) — 로컬에서 모집 열기 흐름을
# 확인하려면 true로. 비워두면 application.yml 기본값(false)이 적용돼 막힌다.
RECRUITMENT_APPLICATION_FORM_READY=

# Mail (OCI Email Delivery, SMTP) — 자격증명은 infra/email-delivery.md #75 참고, 로컬은 STAGE 값 사용
MAIL_SMTP_HOST=smtp.email.ap-tokyo-1.oci.oraclecloud.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=noreply@likelion-khu.com