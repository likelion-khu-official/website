SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=
DB_PATH=/app/data/prod.db

# Flyway(#133) — clean 자체를 코드 레벨에서 불가능하게 막는다(prod는 보호돼야 함, #21). 체크섬 불일치가
# 나면(stage처럼 자동 정리하지 않고) 앱 기동이 그냥 실패 → CD 헬스체크 실패 → 자동 롤백으로 이어진다.
SPRING_FLYWAY_CLEAN_DISABLED=true

# 모집 안내 등 일반 사용자 대상 메일의 링크 베이스 — 공개 사이트(prod). application.yml 기본값과
# 동일하지만, stage(.env.stage)와 값이 갈리는 걸 명시적으로 드러내기 위해 여기도 채워둔다.
PUBLIC_SITE_URL=https://likelion-khu.com

# Object Storage — OCI (S3 호환 API). namespace: nrvbyrcay0ao, region: ap-tokyo-1, 버킷 Public
OCI_STORAGE_ENDPOINT=https://nrvbyrcay0ao.compat.objectstorage.ap-tokyo-1.oraclecloud.com
OCI_STORAGE_REGION=ap-tokyo-1
OCI_STORAGE_ACCESS_KEY=
OCI_STORAGE_SECRET_KEY=
OCI_STORAGE_BUCKET=likelion-prod
OCI_STORAGE_PUBLIC_URL=https://objectstorage.ap-tokyo-1.oraclecloud.com/n/nrvbyrcay0ao/b/likelion-prod/o

# Mail — OCI Email Delivery (SMTP, issue #75). 자격증명은 인프라(찬욱)가 안전한 채널로 전달 — 레포엔 값 채우지 말 것
MAIL_SMTP_HOST=smtp.email.ap-tokyo-1.oci.oraclecloud.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=noreply@likelion-khu.com
